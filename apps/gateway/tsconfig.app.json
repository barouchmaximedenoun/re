{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node", "jest"],
    //"rootDir": "src",
    //"rootDirs": ["src", "../../libs/infra/db/src", "../../libs/platform/indentity/src"],
    //"skipLibCheck": true,
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "../../libs/platform/identity/src/**/*.ts",
    "../../libs/infra/db/src/**/*.ts"
  ],
  "exclude": [
    "out-tsc",
    "dist",
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "../../libs/infra/db/src/**/*.spec.ts",
    "../../libs/platform/identity/src/**/*.spec.ts",
    "src/**/*.test.ts",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ],
  "references": [
    {
      "path": "../../libs/platform/identity/tsconfig.lib.json"
    },
    {
      "path": "../../libs/infra/db/tsconfig.lib.json"
    }
  ]
}
